BASE_URL=https://api.deepseek.com
API_KEY=your_key_here
MODEL=deepseek-chat

# --- ChatECNU (华东师范大学，OpenAI 兼容) ---
# 模型与 BaseURL：https://developer.ecnu.edu.cn/vitepress/llm/model.html
# 鉴权与令牌：https://developer.ecnu.edu.cn/vitepress/llm/authorization.html
# 通用对话：https://developer.ecnu.edu.cn/vitepress/llm/api/completions.html
#
# 推荐主模型 ecnu-plus（256K 上下文；平台文档建议尽量避免并行调用）。将下面三行取消注释并填入令牌后，可替换上方的 DeepSeek 配置。
# BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
# API_KEY=your_ecnu_bearer_token
# MODEL=ecnu-plus
#
# 小节问答、关联问答：与主 MODEL 共用 BASE_URL/API_KEY，单独指定模型（默认 ecnu-max；不配则仍用 ecnu-max）。
# 非 ECNU 网关时请改为该网关支持的模型名（可与 MODEL 相同）。
QA_MODEL=ecnu-max
#
# 若出现 429：可把 FIRST_SUBMIT_PASSES=1、保持 FIRST_SUBMIT_OVERLAP 关闭，并酌情降低 TEEN_EXPAND_MAX_WORKERS。

# 可选：第二套 OpenAI 兼容网关（例 DeepSeek），用于与主通道并行的请求分流（首次 overlap 时「书单润色」走这里；小节 8 环节扩展时偶数环节走这里）。
# LLM_PARALLEL_BASE_URL=https://api.deepseek.com
# LLM_PARALLEL_API_KEY=your_deepseek_key
# LLM_PARALLEL_MODEL=deepseek-chat
# LLM_PARALLEL_REQUEST_TIMEOUT_S=120

# Optional
REQUEST_TIMEOUT_S=60
MAX_RETRIES=2
PORT=7860
# 自建 ECS + systemd 部署时由 deploy/breakyourstudy.service 固定为 17860（与 Nginx upstream 一致），无需改 .env。
# GRADIO_SERVER_NAME=0.0.0.0
# 魔搭等 iframe 内：避免 100vh 按外层视口撑裂布局；默认在 /studio_service/ 工作目录自动开启，也可强制 GRADIO_IFRAME_SAFE=1
# GRADIO_IFRAME_SAFE=1

# First "开始生成" step: books + framework each use chat_json_multi this many passes (default 2).
# Set to 1 for faster first response; quality may drop slightly.
# FIRST_SUBMIT_PASSES=1

# When FIRST_SUBMIT_PASSES>=2: run book-list refinement (pass 2+) in parallel with full outline generation
# (outline uses pass-1 book list). If final books JSON differs, one extra "realign" API call runs.
# May hit rate limits on strict TPM; default off.
# FIRST_SUBMIT_OVERLAP=1

# Optional: one minimal API call at startup to reduce first-user latency (requires valid API env; failures ignored).
# WARMUP_ON_START=1

# Teen loop (小节详解): parallel expand for blocks 1–7; each block still does up to 3 tries in its own thread.
# Lower this if the API returns 429 / rate limits (default 7).
# TEEN_EXPAND_MAX_WORKERS=7
